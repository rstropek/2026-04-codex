{
  "name": "@questionnaires/lib",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/client.d.ts",
      "import": "./dist/db/client.js"
    },
    "./schema": {
      "types": "./dist/db/schema.d.ts",
      "import": "./dist/db/schema.js"
    }
  },
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "pnpm build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate-cli.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.8.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.4.3"
  }
}
