prefix_rule(
    pattern = ["npx", "ctx7@latest"],
    decision = "allow",
    justification = "Allow Context7 lookups in this project",
    match = [
      "npx ctx7@latest library Angular How do signal forms work",
      "npx ctx7@latest docs /websites/angular_dev Tell me something about Angular signal forms",
    ],
  )

prefix_rule(
    pattern = ["ctx7"],
    decision = "allow",
    justification = "Allow Context7 lookups in this project",
    match = [
      "ctx7 library \"Model Context Protocol TypeScript SDK\" \"Add a CLI command that runs a stdio MCP server with registerTool, zod inputSchema, outputSchema structuredContent, and tool schemas using anyOf for discriminated union answer types\""
    ],
  )