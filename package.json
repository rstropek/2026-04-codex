{
  "name": "questionnaire-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:e2e": "pnpm --filter @questionnaires/web test:e2e",
    "web": "pnpm --filter @questionnaires/web dev",
    "console": "pnpm --filter @questionnaires/console start"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13"
  }
}
